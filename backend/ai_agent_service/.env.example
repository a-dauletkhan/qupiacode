# Liveblocks
LIVEBLOCKS_SECRET_KEY=sk_dev_xxxxx

# LLM Provider: "claude" or "openai"
LLM_PROVIDER=claude

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (also works with OpenAI-compatible APIs like DeepSeek)
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.deepseek.com

# Server
PORT=3001

# Logging: trace | debug | info | warn | error | fatal (default: info)
# Use "debug" to see evaluation ticks, LLM calls, and decision details
# Use "trace" to dump full LLM context payloads
AI_AGENT_LOG_LEVEL=debug

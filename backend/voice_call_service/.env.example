APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Local dev defaults. In production, replace these with your LiveKit Cloud values.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LOG_LEVEL=INFO
VOICE_TOKEN_TTL_SECONDS=3600
# Comma-separated exact origins allowed to call the API from the browser.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Optional regex for preview deployments, for example:
# ^https://.*-your-project\.vercel\.app$
CORS_ALLOWED_ORIGIN_REGEX=

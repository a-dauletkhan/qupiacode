APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
VOICE_AGENT_CONNECT_ROOM=canvas:demo-canvas

SUPABASE_URL=
# Public/anon key used for Supabase Auth calls.
SUPABASE_KEY=
# Required for backend board metadata reads/writes.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=canvas-media
LIVEBLOCKS_SECRET_KEY=
HIGGSFIELD_API_URL=https://platform.higgsfield.ai/higgsfield-ai/soul/standard
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_KEY_SECRET=
HIGGSFIELD_RESOLUTION=720p
AI_AGENT_SERVICE_URL=http://ai-agent:3001
AI_AGENT_INTERNAL_TOKEN=dev-ai-agent-token

LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LOG_LEVEL=INFO
VOICE_TOKEN_TTL_SECONDS=3600
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEX=

VOICE_AGENT_ENABLED=true
VOICE_AGENT_NAME=Qupia Agent
VOICE_AGENT_WAKE_PHRASES=agent,hey agent,ai agent
VOICE_AGENT_TRANSCRIPTION_MODE=mock
VOICE_AGENT_STT_MODEL=assemblyai/universal-streaming
VOICE_AGENT_STT_LANGUAGE=en
# Optional override if you want to forward transcripts somewhere other than ai-agent.
VOICE_AGENT_TRANSCRIPT_FORWARD_URL=
VOICE_AGENT_TRANSCRIPT_FORWARD_AUTH_TOKEN=
VOICE_AGENT_TRANSCRIPT_FORWARD_PARTIALS_ENABLED=false
VOICE_AGENT_RECORDING_ENABLED=false
VOICE_AGENT_RECORDING_S3_BUCKET=
VOICE_AGENT_RECORDING_S3_REGION=
VOICE_AGENT_RECORDING_S3_ENDPOINT=
VOICE_AGENT_RECORDING_S3_ACCESS_KEY=
VOICE_AGENT_RECORDING_S3_SECRET_KEY=
VOICE_AGENT_RECORDING_S3_FORCE_PATH_STYLE=true
VOICE_AGENT_RECORDING_PREFIX=recordings
VOICE_AGENT_MOCK_TRANSCRIPT_TEMPLATE=[mock] {participant_name} shared a prototype update.
VOICE_AGENT_TRANSCRIPT_PARTIALS_ENABLED=true
VOICE_AGENT_DIARIZATION_ENABLED=false

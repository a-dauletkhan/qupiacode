# Local dev: Vite proxies /api requests to the FastAPI backend.
VITE_VOICE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: set this when the frontend should call the backend directly
# instead of using the Vite dev proxy, for example in preview or production.
#  VITE_VOICE_API_BASE_URL=https://qupiacode-production.up.railway.app
 VITE_VOICE_API_BASE_URL=https://qupiacode-production.up.railway.app
